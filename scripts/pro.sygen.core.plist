<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sygen core LaunchAgent (native macOS install). Runs the FastAPI/aiohttp
  service installed in __VENV_DIR__/bin/sygen.

  Placeholders substituted by install.sh:
    __VENV_DIR__            absolute path to the Python venv (e.g.
                            /Users/<user>/.sygen-local/venv)
    __SYGEN_ROOT__          data/.env/logs root (e.g. ~/.sygen-local)
    __SYGEN_ADMIN_PORT__    host port of pro.sygen.admin (Next.js)
    __SYGEN_UPDATER_PORT__  host port of pro.sygen.updater
    __HOME__                user's home dir (for $HOME-relative log paths)
    __APNS_KEY_ID__         APNs Key ID (10-char) — empty when push disabled
    __APNS_TEAM_ID__        Apple developer team ID — empty when push disabled
    __APNS_BUNDLE_ID__      iOS app bundle id — empty when push disabled
    __APNS_ENVIRONMENT__    "production" | "sandbox" — empty when push disabled
    __CLAUDE_CLI_PATH__     absolute path to the ``claude`` binary, resolved
                            during install (Homebrew / npm-global / local
                            Claude install). Empty if install.sh could not
                            find one — core will then auto-probe at runtime.
    __SYGEN_WEBHOOK_TRUSTED_PROXIES__
                            CSV of trusted reverse-proxy CIDRs/IPs for the
                            public /webhooks/{slug} ingress (1.6.173 HIGH-1).
                            Empty → core ignores X-Forwarded-For entirely
                            (safe for localhost / PF-direct binds). Set by
                            install.sh per submode: nginx-fronted picks
                            127.0.0.1,::1; tailscale picks 127.0.0.1 plus
                            Tailscale CGNAT range (100.64.0.0/10).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>            <string>pro.sygen.core</string>
    <key>ProgramArguments</key>
    <array>
        <string>__VENV_DIR__/bin/sygen</string>
    </array>
    <key>WorkingDirectory</key> <string>__SYGEN_ROOT__</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>SYGEN_HOME</key>              <string>__SYGEN_ROOT__/data</string>
        <!--
          Sub-agent isolation: HOME points at SYGEN_ROOT/data so Claude
          CLI auth (~/.claude/.credentials.json) lives inside the install
          tree, not in the user's real $HOME. Otherwise every install on
          this machine shares one credential file with the desktop Claude
          app and any legacy Atlas/main install — multiple sygen instances
          would fight over the same OAuth tokens.
        -->
        <key>HOME</key>                    <string>__SYGEN_ROOT__/data</string>
        <key>PATH</key>                    <string>__VENV_DIR__/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <!--
          Mirror the SYGEN_* env vars that systemd's EnvironmentFile=.env
          provides on Linux. launchd has no EnvironmentFile equivalent, so
          without these the core process falls back to $SYGEN_HOME/...
          (= $SYGEN_ROOT/data/...) and writes/reads diverge from the
          host-side runners that watch $SYGEN_ROOT/host_updates etc.
        -->
        <key>SYGEN_HOST_UPDATES_DIR</key>  <string>__SYGEN_ROOT__/host_updates</string>
        <key>SYGEN_HOST_METRICS_DIR</key>  <string>__SYGEN_ROOT__/host_metrics</string>
        <key>SYGEN_UPDATES_STATE</key>     <string>__SYGEN_ROOT__/host_updates/_updates.json</string>
        <key>SYGEN_UPDATER_URL</key>       <string>http://127.0.0.1:__SYGEN_UPDATER_PORT__</string>
        <key>SYGEN_UPDATER_TOKEN</key>     <string>__SYGEN_UPDATER_TOKEN__</string>
        <key>SYGEN_HOST_TZ</key>           <string>__SYGEN_HOST_TZ__</string>
        <!--
          Whisper model dir lives under the operator's real $HOME (where
          deploy_whisper.sh + install.sh's section 5e write it). Since the
          HOME override above redirects Path.home() into SYGEN_ROOT/data,
          transcription.py would otherwise fail with "model not found"
          even after a successful whisper deploy.
        -->
        <key>SYGEN_HOST_WHISPER_MODELS_DIR</key> <string>__HOME__/.local/share/whisper-cpp/models</string>
        <key>ADMIN_INTERNAL_URL</key>      <string>http://127.0.0.1:__SYGEN_ADMIN_PORT__</string>
        <!--
          APNs push (iOS). All four keys must be populated for the
          backend to enable push delivery; absent or empty values keep
          push silently disabled (push_apns.py logs once, then no-op).
          The .p8 auth key is discovered via
          ${SYGEN_HOME}/_secrets/AuthKey_*.p8 — no plist override needed.
        -->
        <key>APNS_KEY_ID</key>             <string>__APNS_KEY_ID__</string>
        <key>APNS_TEAM_ID</key>            <string>__APNS_TEAM_ID__</string>
        <key>APNS_BUNDLE_ID</key>          <string>__APNS_BUNDLE_ID__</string>
        <key>APNS_ENVIRONMENT</key>        <string>__APNS_ENVIRONMENT__</string>
        <!--
          Resolved path to the ``claude`` CLI binary. launchd does not
          source ``~/.zshrc``/``~/.bashrc``, so the inherited ``PATH``
          above only covers Homebrew + system bins. If ``claude`` lives
          elsewhere (npm-global, ``~/.claude/local/claude``, custom
          install), shutil.which() inside the core returns None and the
          OAuth wizard / streaming subprocess both fail with "claude CLI
          not found at 'claude'". install.sh writes the absolute path
          here so PATH lookups don't need to succeed.
        -->
        <key>CLAUDE_CLI_PATH</key>         <string>__CLAUDE_CLI_PATH__</string>
        <!--
          1.6.173 HIGH-1: trusted-proxies allowlist for X-Forwarded-For
          parsing on POST /webhooks/{slug}. Empty by default so a Mac
          localhost install ignores spoofed XFF entirely. install.sh
          fills in 127.0.0.1,::1 for nginx-fronted (publicdomain) and
          127.0.0.1,100.64.0.0/10 for tailscale submode. launchd does
          not load .env, so the value must be mirrored here.
        -->
        <key>SYGEN_WEBHOOK_TRUSTED_PROXIES</key> <string>__SYGEN_WEBHOOK_TRUSTED_PROXIES__</string>
    </dict>
    <key>RunAtLoad</key>        <true/>
    <key>KeepAlive</key>        <true/>
    <key>ThrottleInterval</key> <integer>10</integer>
    <key>StandardOutPath</key>  <string>__SYGEN_ROOT__/logs/core.log</string>
    <key>StandardErrorPath</key><string>__SYGEN_ROOT__/logs/core.log</string>
</dict>
</plist>
