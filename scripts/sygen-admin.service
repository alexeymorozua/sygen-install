[Unit]
Description=Sygen admin (Next.js standalone)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sygen
Group=sygen
WorkingDirectory=__ADMIN_DIR__
Environment=NODE_ENV=production
Environment=NEXT_TELEMETRY_DISABLED=1
Environment=HOSTNAME=127.0.0.1
Environment=PORT=__SYGEN_ADMIN_PORT__
ExecStart=__NODE_BIN__ __ADMIN_DIR__/server.js
Restart=always
RestartSec=5
StandardOutput=append:__SYGEN_ROOT__/logs/admin.log
StandardError=append:__SYGEN_ROOT__/logs/admin.log
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
ReadWritePaths=__SYGEN_ROOT__

[Install]
WantedBy=multi-user.target
