[Unit]
Description=Sygen updater (GitHub Releases poll + atomic swap)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__SYGEN_ROOT__
EnvironmentFile=__SYGEN_ROOT__/.env
# SYGEN_HOME — the data subfolder, matching what sygen-core sees so
# updater reads/writes manifest + .env via the same conventions.
Environment=SYGEN_HOME=__SYGEN_ROOT__/data
# HOME points at SYGEN_ROOT so any tools that expand ~ (Claude CLI,
# pip cache during Apply Update, etc.) land inside the writable tree.
Environment=HOME=__SYGEN_ROOT__
Environment=PATH=__VENV_DIR__/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=__VENV_DIR__/bin/sygen-updater
Restart=on-failure
RestartSec=10
StandardOutput=append:__SYGEN_ROOT__/logs/updater.log
StandardError=append:__SYGEN_ROOT__/logs/updater.log
# Updater stays root (needs systemctl restart + chown across the venv/admin
# swap), but it does not need extra capabilities — drop them defensively.
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target
